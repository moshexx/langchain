# OpenAI API key for using GPT models (e.g., gpt-4o-mini, gpt-4o)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key for using Claude models (e.g., claude-3-5-sonnet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Enable/Disable LangSmith tracing (set to false to avoid network latency/timeouts during local development)
LANGCHAIN_TRACING_V2=false

# The API endpoint for LangSmith tracing
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# Your LangSmith API key for authenticating telemetry data
LANGCHAIN_API_KEY=your_langchain_api_key_here

# User agent string to identify your application requests to LangChain services
USER_AGENT="your_user_agent_here"

